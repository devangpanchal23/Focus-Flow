{
    "manifest_version": 3,
    "name": "BlitzIt Focus Helper",
    "version": "1.0",
    "description": "Helper extension for BlitzIt to block distracting websites.",
    "permissions": [
        "storage",
        "declarativeNetRequest"
    ],
    "host_permissions": [
        "*://*/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "http://localhost:5173/*",
                "http://localhost:3000/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "BlitzIt Block"
    }
}