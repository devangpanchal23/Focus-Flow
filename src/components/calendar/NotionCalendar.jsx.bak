import React, { useState, useEffect } from 'react';
import { Calendar as CalendarIcon, Link as LinkIcon, AlertCircle, Loader2, CheckCircle, ExternalLink, RefreshCw, X, Plus } from 'lucide-react';
import { useTaskStore } from '../../store/useTaskStore';
import { format, parseISO } from 'date-fns';

export default function Calendar() {
    const { authToken } = useTaskStore();
    const [status, setStatus] = useState({ isConnected: false, checking: true });
    const [events, setEvents] = useState([]);
    const [loading, setLoading] = useState(false);
    const [dbIdInput, setDbIdInput] = useState('');
    const [error, setError] = useState(null);
    const [successMsg, setSuccessMsg] = useState(null);

    // Create Event Logic
    const [showCreateModal, setShowCreateModal] = useState(false);
    const [newEvent, setNewEvent] = useState({ title: '', startDate: '', status: '' });
    const [creating, setCreating] = useState(false);
    // Update Event Logic
    const [editingEvent, setEditingEvent] = useState(null);
    const [updating, setUpdating] = useState(false);

    const [view, setView] = useState('list'); // 'list' or 'grid' (not implementing full grid yet for simplicity, stick to list of events per prompts expectation of "views" - let's do a nice list grouped by date)

    useEffect(() => {
        if (authToken) {
            checkStatus();
        }
    }, [authToken]);

    useEffect(() => {
        if (status.isConnected && authToken) {
            fetchEvents();
        }
    }, [status.isConnected]);

    const checkStatus = async () => {
        try {
            const res = await fetch('/api/notion/status', {
                headers: { 'Authorization': `Bearer ${authToken}` }
            });
            const data = await res.json();
            setStatus({ isConnected: data.isConnected, checking: false, databaseId: data.databaseId });
            if (data.databaseId) setDbIdInput(data.databaseId);
        } catch (err) {
            console.error(err);
            setStatus(prev => ({ ...prev, checking: false }));
        }
    };

    const fetchEvents = async () => {
        setLoading(true);
        setError(null);
        try {
            const res = await fetch('/api/notion/calendar', {
                headers: { 'Authorization': `Bearer ${authToken}` }
            });
            if (!res.ok) throw new Error('Failed to fetch calendar');
            const data = await res.json();
            setEvents(data);
        } catch (err) {
            setError(err.message);
        } finally {
            setLoading(false);
        }
    };

    // Helper to extract ID from URL
    const extractDatabaseId = (input) => {
        if (!input) return '';

        // 1. Regex for 32-char hex (standard Notion URL format)
        // e.g. https://notion.so/user/My-Page-1234567890abcdef1234567890abcdef
        const hexMatch = input.match(/([a-f0-9]{32})/);

        // 2. Regex for UUID with dashes (e.g. from a query param or raw ID)
        // e.g. 12345678-90ab-cdef-1234-567890abcdef
        const uuidMatch = input.match(/([a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12})/);

        // Prefer UUID match if explicit, otherwise hex match
        if (uuidMatch && uuidMatch[1]) {
            return uuidMatch[1]; // Keep dashes, API accepts them
        }
        if (hexMatch && hexMatch[1]) {
            return hexMatch[1];
        }

        // Fallback: If it's a short string (likely raw ID), clean it. 
        // If it's a long URL and regex failed, returning cleaned URL is bad (garbage).
        // Only strip dashes if the input looks like a raw ID (length < 50).
        if (input.length < 50) {
            return input.replace(/-/g, '');
        }

        return null; // Fail if we can't find an ID in a long string
    };

    const handleConnect = async (e) => {
        e.preventDefault();
        setLoading(true);
        setError(null);
        setSuccessMsg(null);

        const cleanId = extractDatabaseId(dbIdInput);
        if (!cleanId) {
            setError("Could not find a valid Database ID in that link.");
            setLoading(false);
            return;
        }

        try {
            const res = await fetch('/api/notion/connect', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${authToken}`
                },
                body: JSON.stringify({ databaseId: cleanId })
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.message);

            setStatus({ isConnected: true, checking: false, databaseId: cleanId });
            setSuccessMsg('Successfully connected to Notion!');
            setTimeout(fetchEvents, 500);
        } catch (err) {
            setError(err.message);
        } finally {
            setLoading(false);
        }
    };

    const handleCreateEvent = async (e) => {
        e.preventDefault();
        if (!newEvent.title || !newEvent.startDate) return;

        setCreating(true);
        try {
            const res = await fetch('/api/notion/create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${authToken}`
                },
                body: JSON.stringify(newEvent)
            });

            if (!res.ok) {
                const d = await res.json();
                throw new Error(d.message || d.details || 'Failed to create');
            }

            const createdEvent = await res.json();
            setEvents([...events, createdEvent]); // Optimistic-ish add
            setShowCreateModal(false);
            setNewEvent({ title: '', startDate: '', status: '' });
            setSuccessMsg('Event created in Notion!');

            // Refresh to get order right
            fetchEvents();
        } catch (err) {
            alert('Error creating event: ' + err.message);
        } finally {
            setCreating(false);
        }
    };

    const handleUpdateEvent = async (e) => {
        e.preventDefault();
        if (!editingEvent || !editingEvent.title) return;

        setUpdating(true);
        try {
            // If date is empty string, send null/undefined or handle in backend? Backend expects ISO or generic.
            // If user clears date, we might want to support clearing it. For now assuming date required or kept as is.

            const res = await fetch('/api/notion/update', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${authToken}`
                },
                body: JSON.stringify(editingEvent)
            });

            if (!res.ok) {
                const d = await res.json();
                throw new Error(d.message || d.details || 'Failed to update');
            }

            const updatedEvent = await res.json();

            // Update local state
            setEvents(events.map(ev => ev.id === updatedEvent.id ? updatedEvent : ev));

            setEditingEvent(null);
            setSuccessMsg('Event updated in Notion!');

        } catch (err) {
            alert('Error updating event: ' + err.message);
        } finally {
            setUpdating(false);
        }
    };

    const [appending, setAppending] = useState(false);
    const [pageContent, setPageContent] = useState('');

    const handleAppendContent = async (e) => {
        e.preventDefault();
        if (!editingEvent || !pageContent.trim()) return;

        setAppending(true);
        try {
            const res = await fetch('/api/notion/append-content', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${authToken}`
                },
                body: JSON.stringify({
                    id: editingEvent.id,
                    content: pageContent
                })
            });

            if (!res.ok) {
                const d = await res.json();
                throw new Error(d.message || 'Failed to add content');
            }

            setPageContent('');
            alert('Text added to Notion Page!');
        } catch (err) {
            alert('Error adding content: ' + err.message);
        } finally {
            setAppending(false);
        }
    };

    const handleDisconnect = async () => {
        if (!confirm('Are you sure you want to disconnect?')) return;
        try {
            await fetch('/api/notion/disconnect', {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${authToken}` }
            });
            setStatus({ isConnected: false, checking: false, databaseId: '' });
            setEvents([]);
            setDbIdInput('');
        } catch (err) {
            console.error(err);
        }
    };

    const openEditModal = (event) => {
        // Format date for input datetime-local
        let formattedDate = '';
        if (event.startDate) {
            // Need YYYY-MM-DDTHH:mm
            const d = new Date(event.startDate);
            d.setMinutes(d.getMinutes() - d.getTimezoneOffset());
            formattedDate = d.toISOString().slice(0, 16);
        }

        setEditingEvent({
            ...event,
            startDate: formattedDate
        });
    };

    // Helper to group events by date
    const groupedEvents = events.reduce((acc, event) => {
        // Handle Dateless items
        const dateStr = event.startDate || 'No Date';
        if (!acc[dateStr]) acc[dateStr] = [];
        acc[dateStr].push(event);
        return acc;
    }, {});

    // Sort: Dates first, then "No Date" at the end (or beginning, let's do end)
    const sortedDates = Object.keys(groupedEvents).sort((a, b) => {
        if (a === 'No Date') return 1;
        if (b === 'No Date') return -1;
        return a.localeCompare(b);
    });

    if (status.checking) {
        return <div className="flex justify-center p-20"><Loader2 className="animate-spin text-slate-400" size={32} /></div>;
    }

    return (
        <div className="max-w-6xl mx-auto p-6 space-y-8 animate-in fade-in duration-500 relative">
            {/* Header */}
            <div className="flex flex-col md:flex-row md:items-center justify-between gap-4">
                <div>
                    <h1 className="text-3xl font-bold text-slate-800 dark:text-white flex items-center gap-3">
                        <span className="bg-slate-100 dark:bg-slate-800 p-2 rounded-xl text-slate-800 dark:text-slate-200">
                            <CalendarIcon size={32} />
                        </span>
                        Notion Calendar
                    </h1>
                    <p className="text-slate-500 dark:text-slate-400 mt-1 ml-16">Sync your events securely from your Notion workspace.</p>
                </div>
                {status.isConnected && (
                    <div className="flex items-center gap-3 ml-16 md:ml-0">
                        <button
                            onClick={fetchEvents}
                            disabled={loading}
                            className="p-2 text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors"
                            title="Refresh"
                        >
                            <RefreshCw size={20} className={loading ? "animate-spin" : ""} />
                        </button>
                        <button
                            onClick={handleDisconnect}
                            className="text-sm text-red-500 hover:text-red-700 font-medium px-4 py-2 hover:bg-red-50 dark:hover:bg-red-900/10 rounded-lg transition-colors"
                        >
                            Disconnect
                        </button>
                    </div>
                )}
            </div>

            {!status.isConnected ? (
                /* Connect State */
                <div className="bg-white dark:bg-slate-800 rounded-3xl p-10 border border-slate-200 dark:border-slate-700 shadow-sm text-center max-w-2xl mx-auto">
                    <div className="w-16 h-16 bg-slate-100 dark:bg-slate-700 rounded-full flex items-center justify-center mx-auto mb-6 text-slate-800 dark:text-slate-200">
                        <LinkIcon size={32} />
                    </div>
                    <h2 className="text-2xl font-bold text-slate-900 dark:text-white mb-2">Connect your Notion Calendar</h2>
                    <p className="text-slate-600 dark:text-slate-400 mb-8 max-w-lg mx-auto">
                        Paste the full link to your Notion Database (view as Full Page to get the link).
                    </p>

                    <form onSubmit={handleConnect} className="max-w-md mx-auto space-y-4">
                        <div className="text-left">
                            <label className="text-xs font-bold uppercase tracking-wider text-slate-500 mb-1 block ml-1">Database or Page Link</label>
                            <input
                                type="text"
                                value={dbIdInput}
                                onChange={(e) => setDbIdInput(e.target.value)}
                                placeholder="https://notion.so/..."
                                className="w-full p-4 rounded-xl border border-slate-200 dark:border-slate-600 bg-slate-50 dark:bg-slate-900 text-slate-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none transition-all text-sm font-mono"
                            />
                        </div>

                        <button
                            type="submit"
                            disabled={loading || !dbIdInput}
                            className="w-full bg-slate-900 dark:bg-white text-white dark:text-slate-900 font-bold py-4 rounded-xl hover:opacity-90 transition-opacity disabled:opacity-50 flex items-center justify-center gap-2"
                        >
                            {loading && <Loader2 className="animate-spin" size={20} />}
                            Connect Notion
                        </button>
                    </form>
                    {error && (
                        <div className="mt-6 p-4 bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 rounded-xl text-sm flex items-start gap-2 text-left">
                            <AlertCircle size={18} className="shrink-0 mt-0.5" />
                            <span>{error}</span>
                        </div>
                    )}
                </div>
            ) : (
                /* Calendar View */
                <div className="space-y-6">
                    {successMsg && (
                        <div className="bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 p-4 rounded-xl flex items-center gap-2 mb-4">
                            <CheckCircle size={20} /> {successMsg}
                            <button className="ml-auto" onClick={() => setSuccessMsg(null)}><X size={16} /></button>
                        </div>
                    )}

                    {error && (
                        <div className="bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 p-4 rounded-xl flex items-center gap-2">
                            <AlertCircle size={20} /> {error}
                        </div>
                    )}

                    {/* View Controls */}
                    <div className="flex flex-col sm:flex-row justify-between items-end border-b border-slate-200 dark:border-slate-700 pb-1 gap-4">
                        <div className="flex gap-2 w-full sm:w-auto overflow-x-auto">
                            <button
                                onClick={() => setView('list')}
                                className={`px-5 py-2.5 font-bold text-sm rounded-t-lg transition-colors whitespace-nowrap ${view === 'list' ? 'bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-white border-b-2 border-blue-500' : 'text-slate-500 hover:text-slate-700 hover:bg-slate-50 dark:hover:bg-slate-800/50'}`}
                            >
                                Agenda View
                            </button>
                            <button
                                onClick={() => setView('table')}
                                className={`px-5 py-2.5 font-bold text-sm rounded-t-lg transition-colors whitespace-nowrap ${view === 'table' ? 'bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-white border-b-2 border-blue-500' : 'text-slate-500 hover:text-slate-700 hover:bg-slate-50 dark:hover:bg-slate-800/50'}`}
                            >
                                Database View
                            </button>
                        </div>
                        <button
                            onClick={() => setShowCreateModal(true)}
                            className="flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-bold text-sm shadow-sm transition-all active:scale-95 mb-2 shrink-0"
                        >
                            <Plus size={18} /> New Event
                        </button>
                    </div>

                    {loading && events.length === 0 ? (
                        <div className="flex justify-center p-20"><Loader2 className="animate-spin text-slate-400" size={32} /></div>
                    ) : sortedDates.length === 0 ? (
                        <div className="text-center py-20 bg-slate-50 dark:bg-slate-800/50 rounded-3xl border-2 border-dashed border-slate-300 dark:border-slate-700">
                            <p className="text-slate-500 font-medium">No events found.</p>
                            <button onClick={() => setShowCreateModal(true)} className="text-blue-500 hover:underline mt-2">Create one?</button>
                        </div>
                    ) : (
                        <div className="space-y-8">
                            {view === 'list' ? (
                                /* Agenda View */
                                sortedDates.map(dateStr => (
                                    <div key={dateStr} className="animate-in slide-in-from-bottom-2 duration-500">
                                        <h3 className="text-sm font-bold text-slate-400 uppercase tracking-wider mb-4 sticky top-0 bg-slate-50 dark:bg-slate-950 py-2 z-10 transition-colors">
                                            {dateStr === 'No Date' ? 'No Date' : format(parseISO(dateStr), 'EEEE, MMMM do')}
                                        </h3>
                                        <div className="grid gap-3">
                                            {groupedEvents[dateStr].map(event => (
                                                <div key={event.id} onClick={() => openEditModal(event)} className="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 p-5 rounded-xl hover:shadow-md transition-shadow flex items-center justify-between group cursor-pointer hover:border-blue-500/30">
                                                    <div>
                                                        <h4 className="font-semibold text-slate-800 dark:text-white text-lg mb-1">{event.title}</h4>
                                                        <div className="flex items-center gap-3 text-sm text-slate-500 dark:text-slate-400">
                                                            {event.startDate && <span>{format(parseISO(event.startDate), 'h:mm a')}</span>}
                                                            {event.status && (
                                                                <span className="bg-slate-100 dark:bg-slate-700 px-2 py-0.5 rounded text-xs font-medium">
                                                                    {event.status}
                                                                </span>
                                                            )}
                                                        </div>
                                                    </div>
                                                    {event.url && (
                                                        <a
                                                            href={event.url}
                                                            target="_blank"
                                                            rel="noreferrer"
                                                            onClick={(e) => e.stopPropagation()}
                                                            className="p-2 text-slate-300 hover:text-blue-500 transition-colors"
                                                        >
                                                            <ExternalLink size={20} />
                                                        </a>
                                                    )}
                                                </div>
                                            ))}
                                        </div>
                                    </div>
                                ))
                            ) : (
                                /* Table View */
                                <div className="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 overflow-hidden animate-in fade-in">
                                    <div className="overflow-x-auto">
                                        <table className="w-full text-left text-sm">
                                            <thead className="bg-slate-50 dark:bg-slate-900 border-b border-slate-200 dark:border-slate-700">
                                                <tr>
                                                    <th className="px-6 py-4 font-bold text-slate-500 uppercase tracking-wider">Title</th>
                                                    <th className="px-6 py-4 font-bold text-slate-500 uppercase tracking-wider">Date</th>
                                                    <th className="px-6 py-4 font-bold text-slate-500 uppercase tracking-wider">Status</th>
                                                    <th className="px-6 py-4 font-bold text-slate-500 uppercase tracking-wider text-right">Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody className="divide-y divide-slate-100 dark:divide-slate-700">
                                                {events.map(event => (
                                                    <tr key={event.id} onClick={() => openEditModal(event)} className="hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors cursor-pointer">
                                                        <td className="px-6 py-4 font-medium text-slate-900 dark:text-white">{event.title}</td>
                                                        <td className="px-6 py-4 text-slate-600 dark:text-slate-400">
                                                            {event.startDate ? format(parseISO(event.startDate), 'MMM d, yyyy h:mm a') : <span className="text-slate-300 italic">No Date</span>}
                                                        </td>
                                                        <td className="px-6 py-4">
                                                            {event.status ? (
                                                                <span className="bg-slate-100 dark:bg-slate-700 px-2.5 py-1 rounded text-xs font-medium text-slate-600 dark:text-slate-300">
                                                                    {event.status}
                                                                </span>
                                                            ) : <span className="text-slate-300">-</span>}
                                                        </td>
                                                        <td className="px-6 py-4 text-right flex justify-end gap-2" onClick={(e) => e.stopPropagation()}>
                                                            <button
                                                                onClick={() => openEditModal(event)}
                                                                className="p-1.5 text-slate-400 hover:text-blue-500 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-md transition-colors"
                                                            >
                                                                Edit
                                                            </button>
                                                            {event.url && (
                                                                <a
                                                                    href={event.url}
                                                                    target="_blank"
                                                                    rel="noreferrer"
                                                                    className="p-1.5 text-slate-400 hover:text-blue-500 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-md transition-colors"
                                                                >
                                                                    <ExternalLink size={16} />
                                                                </a>
                                                            )}
                                                        </td>
                                                    </tr>
                                                ))}
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            )}
                        </div>
                    )}
                </div>
            )}

            {/* Create Modal */}
            {showCreateModal && (
                <div className="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4 backdrop-blur-sm">
                    <div className="bg-white dark:bg-slate-800 rounded-2xl p-6 w-full max-w-md shadow-2xl animate-in zoom-in-95 duration-200">
                        <div className="flex justify-between items-center mb-6">
                            <h3 className="text-xl font-bold text-slate-900 dark:text-white">New Notion Page</h3>
                            <button onClick={() => setShowCreateModal(false)} className="text-slate-400 hover:text-slate-600"><X size={24} /></button>
                        </div>
                        <form onSubmit={handleCreateEvent} className="space-y-4">
                            <div>
                                <label className="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Title</label>
                                <input
                                    autoFocus
                                    type="text"
                                    value={newEvent.title}
                                    onChange={e => setNewEvent({ ...newEvent, title: e.target.value })}
                                    className="w-full p-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none"
                                    placeholder="Meeting with Team"
                                    required
                                />
                            </div>
                            <div>
                                <label className="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Date</label>
                                <input
                                    type="datetime-local"
                                    value={newEvent.startDate}
                                    onChange={e => setNewEvent({ ...newEvent, startDate: e.target.value })}
                                    className="w-full p-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none"
                                    required
                                />
                            </div>
                            <div>
                                <label className="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Status (Optional)</label>
                                <input
                                    type="text"
                                    value={newEvent.status}
                                    onChange={e => setNewEvent({ ...newEvent, status: e.target.value })}
                                    className="w-full p-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none"
                                    placeholder="To Do, In Progress..."
                                />
                            </div>
                            <div className="pt-4 flex gap-3">
                                <button
                                    type="button"
                                    onClick={() => setShowCreateModal(false)}
                                    className="flex-1 py-3 rounded-xl border border-slate-200 dark:border-slate-700 font-medium hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors"
                                >
                                    Cancel
                                </button>
                                <button
                                    type="submit"
                                    disabled={creating}
                                    className="flex-1 py-3 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-bold transition-colors flex justify-center items-center gap-2"
                                >
                                    {creating && <Loader2 className="animate-spin" size={18} />}
                                    Create
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            )}

            {/* Edit Modal */}
            {editingEvent && (
                <div className="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4 backdrop-blur-sm">
                    <div className="bg-white dark:bg-slate-800 rounded-2xl p-6 w-full max-w-md shadow-2xl animate-in zoom-in-95 duration-200 flex flex-col max-h-[90vh]">
                        <div className="flex justify-between items-center mb-4 shrink-0">
                            <h3 className="text-xl font-bold text-slate-900 dark:text-white">Edit Event / Page</h3>
                            <button onClick={() => setEditingEvent(null)} className="text-slate-400 hover:text-slate-600"><X size={24} /></button>
                        </div>

                        <div className="overflow-y-auto pr-2 space-y-6">
                            {/* Properties Form */}
                            <form onSubmit={handleUpdateEvent} className="space-y-4 border-b border-slate-200 dark:border-slate-700 pb-6">
                                <h4 className="text-sm font-bold uppercase text-slate-500 tracking-wider">Properties</h4>
                                <div>
                                    <label className="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Title</label>
                                    <input
                                        type="text"
                                        value={editingEvent.title}
                                        onChange={e => setEditingEvent({ ...editingEvent, title: e.target.value })}
                                        className="w-full p-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none"
                                        required
                                    />
                                </div>
                                <div>
                                    <label className="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Date</label>
                                    <input
                                        type="datetime-local"
                                        value={editingEvent.startDate}
                                        onChange={e => setEditingEvent({ ...editingEvent, startDate: e.target.value })}
                                        className="w-full p-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none"
                                    />
                                </div>
                                <div>
                                    <label className="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Status</label>
                                    <input
                                        type="text"
                                        value={editingEvent.status || ''}
                                        onChange={e => setEditingEvent({ ...editingEvent, status: e.target.value })}
                                        className="w-full p-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none"
                                    />
                                </div>
                                <button
                                    type="submit"
                                    disabled={updating}
                                    className="w-full py-3 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-bold transition-colors flex justify-center items-center gap-2"
                                >
                                    {updating && <Loader2 className="animate-spin" size={18} />}
                                    Save Properties
                                </button>
                            </form>

                            {/* Add Content Form */}
                            <form onSubmit={handleAppendContent} className="space-y-4">
                                <h4 className="text-sm font-bold uppercase text-slate-500 tracking-wider">Add Page Content</h4>
                                <div>
                                    <textarea
                                        value={pageContent}
                                        onChange={e => setPageContent(e.target.value)}
                                        placeholder="Type something to add to this page in Notion..."
                                        className="w-full p-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 text-slate-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none min-h-[100px]"
                                    />
                                </div>
                                <button
                                    type="submit"
                                    disabled={appending || !pageContent.trim()}
                                    className="w-full py-3 rounded-xl bg-green-600 hover:bg-green-700 text-white font-bold transition-colors flex justify-center items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed"
                                >
                                    {appending && <Loader2 className="animate-spin" size={18} />}
                                    AddTo Page
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            )}
        </div>
    );
}
